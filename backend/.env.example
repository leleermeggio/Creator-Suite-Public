# === Required ===
DATABASE_URL=postgresql+asyncpg://creator:creator@localhost:5432/creator_suite
REDIS_URL=redis://localhost:6379/0

# === Auth (RS256) ===
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# === Object Storage (Cloudflare R2) ===
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=creator-suite

# === AI Services ===
GOOGLE_API_KEY=
WHISPER_MODEL=small
GEMINI_MODEL=gemini-2.0-flash

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8081,http://localhost:19006,http://127.0.0.1:8000
